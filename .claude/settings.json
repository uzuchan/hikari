{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(python3 -m http.server:*)",
      "Bash(python3:*)",
      "Bash(npx serve:*)",
      "Bash(node:*)",
      "Bash(open http://localhost:*)",
      "Bash(open:*)",
      "Bash(lsof:*)",
      "Bash(kill:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(date:*)",
      "Bash(sleep:*)",
      "Bash(echo:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -s -o /dev/null:*)",
      "Bash(curl http://localhost:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(rm -r /:*)"
    ]
  }
}
